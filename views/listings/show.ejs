<% layout("./layouts/boilerplate.ejs") %>

      <div class="container mt-4">

            <h2 class="mb-4">
                  <%= listing.title %>
            </h2>

            <!-- Listing Card -->
            <div class="card show-card">

                  <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing image">

                  <div class="card-body">
                        <p class="card-text">
                              <i>owned by <%= listing.owner.username %></i>
                        </p>

                        <p class="card-text">
                              <strong>Description:</strong><br>
                              <%= listing.description %>
                        </p>

                        <p class="card-text">
                              <strong>Price:</strong>
                              ₹ <%= listing.price.toLocaleString("en-IN") %> / night
                        </p>

                        <p class="card-text">
                              <strong>Location:</strong>
                              <%= listing.location %>, <%= listing.country %>
                        </p>

                        <% if(currentUser && listing.owner._id.equals(currentUser._id)){ %>

                              <div class="d-flex gap-2 mt-4">

                                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
                                          Edit
                                    </a>

                                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                                          <button class="btn btn-danger">
                                                Delete
                                          </button>
                                    </form>

                              </div>

                              <% } %>

                  </div>
            </div>

            <!-- Review Form -->
            <% if(currentUser) { %>

                  <div class="card show-card mt-4">

                        <div class="card-body">

                              <h3 class="mb-3">Leave a Review</h3>

                              <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate
                                    class="needs-validation">

                                    <!-- Rating -->
                                    <div class="mb-3">

                                          <label class="form-label">Rating</label>

                                          <fieldset class="starability-slot">

                                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                                <label for="first-rate1" title="Terrible">
                                                      1 star
                                                </label>

                                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                                <label for="first-rate2" title="Not good">
                                                      2 stars
                                                </label>

                                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                                <label for="first-rate3" title="Average">
                                                      3 stars
                                                </label>

                                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                                <label for="first-rate4" title="Very good">
                                                      4 stars
                                                </label>

                                                <input type="radio" id="first-rate5" name="review[rating]" value="5"
                                                      checked />
                                                <label for="first-rate5" title="Amazing">
                                                      5 stars
                                                </label>

                                          </fieldset>

                                    </div>

                                    <!-- Comments -->
                                    <div class="mb-3">

                                          <label for="comments" class="form-label">
                                                Comments
                                          </label>

                                          <textarea class="form-control" id="comments" name="review[comments]" rows="4"
                                                placeholder="Write your review here..." required></textarea>

                                          <div class="invalid-feedback">
                                                Please add some comments for review
                                          </div>

                                    </div>

                                    <button type="submit" class="btn btn-dark">
                                          Submit Review
                                    </button>

                              </form>

                        </div>

                  </div>

                  <% } %>

                        <!-- All Reviews -->
                        <div class="show-card mt-4">

                              <h3>All Reviews</h3>

                              <div class="row">

                                    <% for(let review of listing.reviews){ %>

                                          <div class="col-md-6 mb-3">

                                                <div class="card">

                                                      <div class="card-body">

                                                            <h5 class="card-title">
                                                                  @<%= review.author.username %>
                                                            </h5>

                                                            <p class="card-text">
                                                                  <%= review.comments %>
                                                            </p>

                                                            <p class="starability-result"
                                                                  data-rating="<%= review.rating %>">
                                                                  Rated <%= review.rating %> stars
                                                            </p>

                                                            <form method="POST"
                                                                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                                                                  <button class="btn btn-dark btn-sm">
                                                                        Delete
                                                                  </button>

                                                            </form>

                                                      </div>

                                                </div>

                                          </div>

                                          <% } %>

                              </div>

                        </div>

      </div>