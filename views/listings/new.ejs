<% layout("/layouts/boilerplate") %>

      <div class="listing-form">

            <div class="card shadow-lg">

                  <div class="card-body p-4 p-md-5">

                        <h2 class="card-title text-center mb-4">
                              Create New Listing
                        </h2>

                        <form method="POST" action="/listings" novalidate class="needs-validation">

                              <div class="mb-3">
                                    <label for="title" class="form-label fw-semibold">
                                          Listing Title
                                    </label>

                                    <input type="text" id="title" name="title" class="form-control"
                                          placeholder="e.g. Luxury Beach House" required>
                                    <div class="valid-feedback">title looks good</div>
                                    <div class="invalid-feedback"> please select title</div>

                              </div>

                              <div class="mb-3">
                                    <label for="description" class="form-label fw-semibold">
                                          Description
                                    </label>

                                    <textarea id="description" name="description" rows="4" class="form-control"
                                          placeholder="Describe your property..." required></textarea>
                                    <div class="invalid-feedback"> description should be short</div>
                              </div>

                              <div class="mb-3">
                                    <label for="imageUrl" class="form-label fw-semibold">
                                          Image URL
                                    </label>

                                    <input type="text" id="imageUrl" name="imageUrl" class="form-control"
                                          placeholder="https://example.com/image.jpg">
                              </div>

                              <div class="mb-3">
                                    <label for="price" class="form-label fw-semibold">
                                          Price (₹ per night)
                                    </label>

                                    <input id="price" name="price" class="form-control" placeholder="2500" required>
                                    <div class="invalid-feedback">please enter valid price</div>
                              </div>

                              <div class="row">

                                    <div class="col-md-6 mb-3">
                                          <label for="location" class="form-label fw-semibold">
                                                Location
                                          </label>

                                          <input type="text" id="location" name="location" class="form-control"
                                                placeholder="Mumbai" required>
                                          <div class="invalid-feedback">location should be valid</div>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                          <label for="country" class="form-label fw-semibold">
                                                Country
                                          </label>

                                          <input type="text" id="country" name="country" class="form-control"
                                                placeholder="India" required>
                                          <div class="invalid-feedback">please enter valid price
                                          </div>
                                    </div>

                              </div>

                              <div class="d-grid mt-4">
                                    <button class="btn btn-submit text-white">
                                          Publish Listing
                                    </button>
                              </div>

                        </form>

                  </div>

            </div>

      </div>