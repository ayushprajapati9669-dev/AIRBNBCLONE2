<% layout("./layouts/boilerplate.ejs") %>

      <body>

            <h1>all listings</h1>

            <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1">
                  <%for(let listing of allListings) {%>

                        <a href="/listings/<%=listing._id%>" class="listing-link">
                              <div class="card col">
                                    <img src="<%=listing.image.url%>" class="card-img-top" alt="listing image"
                                          style="height: 20rem;">
                                    <div class="card-img-overlay overlay-content">
                                          <h5></h5>
                                    </div>
                                    <div class="card-body">
                                          <p class="card-text">
                                                <b>
                                                      <%=listing.title%>
                                                </b> <br>
                                                &#x20B9; <%= listing.price.toLocaleString("en-IN") %> for 2 nights
                                          </p>
                                    </div>
                              </div>
                        </a>


                        <%}%>
            </div>


      </body>